# ─────────────────────────────────────────────────────────────────────────────
# DSN Call Orchestrator — Environment Variables
# Copy to .env and fill in all values before running locally or deploying.
# ─────────────────────────────────────────────────────────────────────────────

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=production

# ── Supabase (source of truth) ────────────────────────────────────────────────
SUPABASE_URL=https://your-dsn-project.supabase.co
SUPABASE_SECRET_KEY=your-supabase-service-role-key

# ── Auth ──────────────────────────────────────────────────────────────────────
# Shared secret for GHL webhook calls — add as header x-webhook-secret in GHL workflow
WEBHOOK_SECRET=generate-a-random-32-char-string

# Secret for Railway cron job curl calls
CRON_SECRET=generate-another-random-32-char-string

# Password for /admin/* dashboard endpoints
ADMIN_PASSWORD=your-secure-admin-password

# Optional: restrict CORS on /admin/* to your dashboard's origin (e.g. https://admin.example.com).
# Defaults to '*' (any origin) if unset.
ADMIN_ALLOWED_ORIGIN=*

# ── GoHighLevel ───────────────────────────────────────────────────────────────
GHL_API_KEY=your-ghl-private-integration-token
GHL_LOCATION_ID=NgduPjDbvABP3zFIqnt4
GHL_CALENDAR_ID=DXh5uGCZVjFLPQNeKRZu   # "Free Consultation" calendar in DSN account

# ── Retell AI ─────────────────────────────────────────────────────────────────
RETELL_API_KEY=your-retell-api-key
RETELL_FROM_NUMBER=+1XXXXXXXXXX          # E.164 — add once DSN phone number is purchased

# Speed-to-lead agent — conversation_flow_9ef584e2f263
RETELL_AGENT_ID_SPEED_TO_LEAD=agent_d7bffee08f5962e2a0c5789fcd

# Reminder agent — conversation_flow_68c0252a092d
RETELL_AGENT_ID_REMINDER=agent_1cf55115cf9e5477adb445c754

# Required — webhook signing key from Retell dashboard (the API key with the "webhook" badge).
# /webhook/retell and /retell/function/* reject all requests with 503 if this is unset (fail closed).
RETELL_WEBHOOK_KEY=your-retell-webhook-signing-key

# Delay from lead creation to first call attempt, milliseconds (default 90s)
# Set lower for faster speed-to-lead; minimum recommended: 30000 (30s) to allow GHL to finish
RETELL_SPEED_TO_LEAD_DELAY_MS=90000

# Delay between first and second dial attempt, milliseconds (default 45s)
RETELL_DOUBLE_DIAL_DELAY_MS=45000

# ── Calling window (TCPA) ─────────────────────────────────────────────────────
# Enforced in the LEAD'S LOCAL TIMEZONE across all call paths. Calls outside the
# window are deferred to the next opening, never dropped. TCPA hard limit is 8–21.
# Defaults below: 8am–6pm, Mon–Sat (Sunday blocked).
CALL_WINDOW_START_HOUR=8          # inclusive, 24h (8 = 8am)
CALL_WINDOW_END_HOUR=18           # exclusive, 24h (18 = 6pm)
CALL_BLOCKED_WEEKDAYS=Sunday      # comma-separated full weekday names, e.g. "Saturday,Sunday"

# ── Call volume safeguards ────────────────────────────────────────────────────
# Circuit breaker: max speed-to-lead calls per rolling hour before that cron stops
# firing new calls and dead-letters the tick.
MAX_CALLS_PER_HOUR=300

# Separate circuit breaker: max appointment-reminder/confirmation calls per rolling
# hour. Kept independent of MAX_CALLS_PER_HOUR so a speed-to-lead volume spike can't
# starve reminder calls (and vice versa).
MAX_REMINDER_CALLS_PER_HOUR=100

# Name the AI agent uses to refer to itself / the closer on reminder calls
CLOSER_NAME=Brian
